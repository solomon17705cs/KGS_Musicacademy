{
  "expo": {
    "name": "KGS Music Academy",
    "slug": "kgs-music-academy",
    "version": "1.3.2",
    "orientation": "portrait",
    "icon": "./Images/logo_fixed.png",
    "splash": {
      "image": "./Images/logo_fixed.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kgsmusicacademy.musicapp"
    },
    "android": {
      "package": "com.kgsmusicacademy.musicapp",
      "adaptiveIcon": {
        "foregroundImage": "./Images/logo_fixed.png",
        "backgroundColor": "#ffffff"
      }
    },
    "androidStatusBar": {
      "translucent": false,
      "backgroundColor": "#ffffff",
      "barStyle": "dark-content"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png",
      "name": "KGS Music Academy",
      "shortName": "KGS Music",
      "description": "Music school management app",
      "backgroundColor": "#ffffff",
      "themeColor": "#1e40af"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "@react-native-community/datetimepicker",
      [
        "expo-notifications",
        {
          "icon": "./Images/logo_fixed.png",
          "color": "#1e40af",
          "defaultChannel": "default",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "bfd160cc-5071-4f86-93b6-dec7d9a291a0"
      }
    },
    "owner": "solomon17705"
  }
}
